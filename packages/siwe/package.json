{
  "name": "@signinwithethereum/ts",
  "version": "3.0.1",
  "type": "module",
  "description": "Sign In with Ethereum",
  "main": "dist/siwe.cjs",
  "module": "dist/siwe.mjs",
  "types": "dist/siwe.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/siwe.d.ts",
        "default": "./dist/siwe.mjs"
      },
      "require": {
        "types": "./dist/siwe.d.ts",
        "default": "./dist/siwe.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "vitest run",
    "build": "vite build",
    "lint": "eslint .",
    "format": "prettier --ignore-path .gitignore --write \"**/*.+(js|ts|json)\""
  },
  "author": "Ethereum Identity Foundation",
  "license": "Apache-2.0",
  "keywords": [
    "ethereum",
    "sign-in",
    "sign-in-with-ethereum",
    "siwe"
  ],
  "homepage": "https://github.com/signinwithethereum/siwe",
  "dependencies": {
    "@stablelib/random": "^1.0.1",
    "@signinwithethereum/ts-parser": "workspace:^"
  },
  "devDependencies": {
    "ethers5": "npm:ethers@^5.6.8",
    "ethers6": "npm:ethers@^6.0.8",
    "viem": "^2.0.0"
  },
  "peerDependencies": {
    "ethers": "^5.6.8 || ^6.0.8",
    "viem": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "ethers": {
      "optional": true
    },
    "viem": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/signinwithethereum/siwe.git"
  },
  "bugs": {
    "url": "https://github.com/signinwithethereum/siwe/issues"
  }
}
